# .env del Jenkins local — NO se sube a git (.gitignore ignora ".env").
# Rellena los dos TOKEN marcados con <<< PEGA_AQUI >>> con tus valores reales.

# Contraseña del admin de Jenkins (cámbiala si quieres).
JENKINS_ADMIN_PASSWORD=Bookplus2026!

# GitHub Container Registry. El usuario ya está; el token lo generas en:
#   GitHub -> Settings -> Developer settings -> Personal access tokens -> Tokens (classic)
#   permiso: write:packages
GHCR_USER=dhuarocc
GHCR_TOKEN=<<< PEGA_AQUI_TU_TOKEN_DE_GHCR >>>

# Token de SonarCloud:  My Account -> Security -> Generate Token
SONAR_TOKEN=d48293c8887a24c70809720f94afb7d251d2fa6b
SONAR_ORGANIZATION=dhuarocc

# Opcionales (solo si activas el bloque Vault en jenkins/casc/jenkins.yaml)
VAULT_ROLE_ID=
VAULT_SECRET_ID=

# --- Modo PROFESIONAL (recomendado): GitHub App en vez de PAT personal ---
# Jenkins acuña tokens efímeros (1h) automáticamente; no se rota nada a mano.
# GitHub App "bookplus-ci" (instalada en dhuarocc/bookplus).
GITHUB_APP_ID=4105762
# Key real PKCS#8, ya convertida y protegida por .gitignore (*.pem). Ruta relativa al compose.
GITHUB_APP_KEY_FILE=./jenkins/casc/github-app.pem
