# ════════════════════════════════════════════════════════════════════════════
#  BookPlus — Environment Variables
#  Copy this file to .env and fill in the values before running docker compose.
#  Generate RSA keys with:  make keys
# ════════════════════════════════════════════════════════════════════════════

# ── JWT RSA Key Pair (RS256) ──────────────────────────────────────────────
# Generated by: scripts/generate-keys.sh
# All services share the same public key to validate tokens.
# Only auth-service uses the private key to sign them.

BOOKPLUS_JWT_PRIVATE_KEY_BASE64=<base64-encoded-PKCS8-private-key>
BOOKPLUS_JWT_PUBLIC_KEY_BASE64=<base64-encoded-X509-public-key>

# ── Service-specific aliases (the full stack uses the shared key above) ──
# These are set automatically by docker-compose.full.yml — no need to change.
AUTH_JWT_PRIVATE_KEY_BASE64=${BOOKPLUS_JWT_PRIVATE_KEY_BASE64}
AUTH_JWT_PUBLIC_KEY_BASE64=${BOOKPLUS_JWT_PUBLIC_KEY_BASE64}
CATALOG_JWT_PUBLIC_KEY_BASE64=${BOOKPLUS_JWT_PUBLIC_KEY_BASE64}
INVENTORY_JWT_PUBLIC_KEY_BASE64=${BOOKPLUS_JWT_PUBLIC_KEY_BASE64}
CART_JWT_PUBLIC_KEY_BASE64=${BOOKPLUS_JWT_PUBLIC_KEY_BASE64}
ORDER_JWT_PUBLIC_KEY_BASE64=${BOOKPLUS_JWT_PUBLIC_KEY_BASE64}
PAYMENT_JWT_PUBLIC_KEY_BASE64=${BOOKPLUS_JWT_PUBLIC_KEY_BASE64}
NOTIFICATION_JWT_PUBLIC_KEY_BASE64=${BOOKPLUS_JWT_PUBLIC_KEY_BASE64}
REPORT_JWT_PUBLIC_KEY_BASE64=${BOOKPLUS_JWT_PUBLIC_KEY_BASE64}
ADMIN_BFF_JWT_PUBLIC_KEY_BASE64=${BOOKPLUS_JWT_PUBLIC_KEY_BASE64}
GATEWAY_JWT_PUBLIC_KEY_BASE64=${BOOKPLUS_JWT_PUBLIC_KEY_BASE64}

# ── CORS (API Gateway) ────────────────────────────────────────────────────
# Comma-separated list of allowed front-end origins.
# Default targets the Angular dev server; set your prod domain when deploying.
CORS_ALLOWED_ORIGINS=http://localhost:4200

# ── Outbox tuning (optional — defaults shown) ─────────────────────────────
ORDER_OUTBOX_POLL_MS=5000

# ── Admin notification email ──────────────────────────────────────────────
ADMIN_EMAIL=admin@bookplus.com
MAIL_FROM=noreply@bookplus.com
