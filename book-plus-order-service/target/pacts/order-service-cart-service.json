              {
                "match": "integer"
              }
            ]
          },
          "$.items[*].title": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          },
          "$.items[*].unitPrice.amount": {
            "combine": "AND",
            "matchers": [
              {
                "match": "decimal"
              }
            ]
          },
          "$.items[*].unitPrice.currency": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          },
          "$.paymentMethod": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          },
          "$.recipientEmail": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          },
          "$.shippingAddress.city": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          },
          "$.shippingAddress.country": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          },
          "$.shippingAddress.postalCode": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          },
          "$.shippingAddress.recipientName": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
              }
            ]
          },
          "$.shippingAddress.state": {
            "combine": "AND",
            "matchers": [
              {
                "match": "type"
