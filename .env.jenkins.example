# Copia este fichero a ".env" (junto a docker-compose.jenkins.yml) y rellena los valores.
# El .env real NO se sube a git (.gitignore ya ignora ".env").

# Contraseña del usuario admin de Jenkins (la creas tú)
JENKINS_ADMIN_PASSWORD=cambia-esta-clave

# --- NIVEL PROFESIONAL: GitHub App (recomendado) ---------------------------
# Tokens efímeros de 1h; nadie renueva nada. Crea la App una vez (ver DUAL-CICD-SETUP.md).
GITHUB_APP_ID=000000
# Ruta ABSOLUTA a tu .pem REAL (en formato PKCS#8). DÉJALO FUERA del repo.
# Ejemplo Windows/Git Bash:  GITHUB_APP_KEY_FILE=/c/Users/W11/.bookplus/github-app.pem
GITHUB_APP_KEY_FILE=

# --- NIVEL 1: PAT (solo si NO usas GitHub App) -----------------------------
# GitHub Container Registry: usuario + Personal Access Token con permiso write:packages
GHCR_USER=dhuarocc
GHCR_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxx

# Token de SonarCloud (Account -> Security -> Generate Token)
SONAR_TOKEN=xxxxxxxxxxxxxxxxxxxx

# (Opcionales — solo si activas el bloque de Vault en jenkins/casc/jenkins.yaml)
VAULT_ROLE_ID=
VAULT_SECRET_ID=
